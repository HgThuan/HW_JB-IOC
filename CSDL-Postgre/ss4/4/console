
CREATE TABLE products (
                          id INT PRIMARY KEY,
                          name VARCHAR(255),
                          category VARCHAR(100),
                          price DECIMAL(18, 2),
                          stock INT NULL,
                          manufacturer VARCHAR(100)
);

