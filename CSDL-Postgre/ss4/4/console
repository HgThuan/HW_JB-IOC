--1. Chèn dữ liệu mới
INSERT INTO products (id, name, category, price, stock, manufacturer)
VALUES (8, N'Chuột không dây Logitech M170', N'Phụ kiện', 300000, 20, N'Logitech');

--2. Cập nhật dữ liệu
UPDATE products
SET price = price * 1.1
WHERE manufacturer = 'Apple';

--3. Xóa dữ liệu
DELETE FROM products
WHERE stock = 0;

--4. Lọc theo điều kiện (Khoảng giá)
SELECT * FROM products
WHERE price BETWEEN 1000000 AND 30000000;

--5. Lọc giá trị NULL
SELECT * FROM products
WHERE stock IS NULL;

--6. Loại bỏ trùng (Hãng sản xuất)
SELECT DISTINCT manufacturer FROM products;

--7. Sắp xếp dữ liệu
SELECT * FROM products
ORDER BY price DESC, name ASC;

--8. Tìm kiếm (Không phân biệt hoa thường)
SELECT * FROM products
WHERE name ILIKE '%laptop%';

--9. Giới hạn kết quả
SELECT * FROM products
ORDER BY price DESC
LIMIT 2;
