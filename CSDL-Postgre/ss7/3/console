--1
EXPLAIN ANALYZE
SELECT * FROM post
WHERE is_public = TRUE AND LOWER(content) LIKE LOWER('Hôm nay%');
--2
CREATE INDEX idx_post_content_lower ON post (LOWER(content));
--3
CREATE INDEX idx_post_tags_gin ON post USING GIN (tags);

EXPLAIN ANALYZE
SELECT * FROM post
WHERE tags @> '{"study"}'; -- Tìm bài viết có chứa tag "study"

--4
CREATE INDEX idx_post_public_recent
    ON post (created_at DESC)
    WHERE is_public = TRUE;

EXPLAIN ANALYZE
SELECT * FROM post
WHERE is_public = TRUE
  AND created_at >= CURRENT_TIMESTAMP - INTERVAL '7 days'
ORDER BY created_at DESC;

CREATE INDEX idx_post_user_timeline ON post (user_id, created_at DESC);

EXPLAIN ANALYZE
SELECT * FROM post
WHERE user_id = 2
ORDER BY created_at DESC
LIMIT 10;


