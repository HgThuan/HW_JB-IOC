--1
select
s.full_name as "Ten sinh vien",
c.course_name as "mon hoc",
e.score as "diem so"
from students s
join enrollments e on s.student_id = e.student_id
join course c on c.course_id = e.course_id;

--2
select
    s.full_name,
    max(e.score) as "Diem cao nhat",
    min(e.score) as "Diem thap nhat",
    avg(e.score) as "diem trung binh"
from students s
join enrollments e on s.student_id = e.student_id
GROUP BY s.full_name;

--3
SELECT s.major,
       AVG(e.score) AS "Điểm trung bình ngành"
FROM students s
         JOIN enrollments e ON s.student_id = e.student_id
GROUP BY s.major
HAVING AVG(e.score) > 7.5;

--4
select
    s.full_name as "Ten sv",
    c.course_name as "Mon hoc",
    c.credit as "tin chi",
    e.score as "diem"
from students s
join enrollments e on s.student_id = e.student_id
join course c on c.course_id = e.course_id;

--5
select
    s.full_name,
    avg(e.score) as "diem tb"
from students s
join enrollments e on s.student_id = e.student_id
group by s.full_name
having avg(e.score) > (select avg(score) from enrollments ) ;

