--1.
select
    e.emp_name,
    d.dept_name,
    e.salary
from departments as d
join employees e on d.dept_id = e.dept_id

--2
select
    sum(salary) as "tong luong",
    avg(salary) as "trung binh luong",
    max(salary) as "luong cao nhat" ,
    min(salary) as "luong thap nhat",
    count(emp_id) as "so nv"
from employees;
--3
select d.dept_name, avg(e.salary) as "avg_salary"
from departments as d
join employees e on d.dept_id = e.dept_id
group by d.dept_name
having avg(salary) >1500;
--4
select
    p.project_name as "ten du an",
    d.dept_name as "phong ban phu trach",
    e.emp_name as "ten nhan vien"
from projects p
join employees e on p.dept_id = e.dept_id
join departments d on d.dept_id = e.dept_id;

--5
select
    emp_name,
    dept_id,
    salary
from employees
where (dept_id, salary) in (
select dept_id, max(salary)
from employees
group by dept_id
    );
