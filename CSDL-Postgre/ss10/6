CREATE OR REPLACE FUNCTION fn_manage_stock()
RETURNS TRIGGER AS $$
DECLARE
    current_stock INT;
BEGIN
    -- 1. XỬ LÝ KHI THÊM ĐƠN HÀNG MỚI (INSERT)
    IF (TG_OP = 'INSERT') THEN
        -- Lấy tồn kho hiện tại
        SELECT stock INTO current_stock FROM products WHERE id = NEW.product_id;
        
        IF current_stock < NEW.quantity THEN
            RAISE EXCEPTION 'Không đủ hàng! Kho còn %, bạn yêu cầu %', current_stock, NEW.quantity;
        END IF;

        UPDATE products SET stock = stock - NEW.quantity WHERE id = NEW.product_id;

    -- 2. XỬ LÝ KHI CẬP NHẬT ĐƠN HÀNG (UPDATE)
    ELSIF (TG_OP = 'UPDATE') THEN
        SELECT stock INTO current_stock FROM products WHERE id = NEW.product_id;
        IF (current_stock - (NEW.quantity - OLD.quantity)) < 0 THEN
            RAISE EXCEPTION 'Cập nhật thất bại! Tồn kho không đủ để đáp ứng số lượng tăng thêm.';
        END IF;

        UPDATE products 
        SET stock = stock - (NEW.quantity - OLD.quantity) 
        WHERE id = NEW.product_id;

    -- 3. XỬ LÝ KHI HỦY/XÓA ĐƠN HÀNG (DELETE)
    ELSIF (TG_OP = 'DELETE') THEN
        UPDATE products SET stock = stock + OLD.quantity WHERE id = OLD.product_id;
    END IF;

    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER trg_orders_stock_sync
BEFORE INSERT OR UPDATE OR DELETE ON orders
FOR EACH ROW
EXECUTE FUNCTION fn_manage_stock();

