CREATE OR REPLACE FUNCTION check_stock_before_sale()
RETURNS TRIGGER AS $$
DECLARE
    current_stock INT;
BEGIN
    -- 1. Lấy số lượng tồn kho hiện tại của sản phẩm
    SELECT stock INTO current_stock FROM products WHERE product_id = NEW.product_id;

    -- 2. So sánh với số lượng khách muốn mua
    IF current_stock < NEW.quantity THEN
        -- Báo lỗi và dừng transaction
        RAISE EXCEPTION 'Không đủ hàng trong kho! (Sản phẩm ID % chỉ còn % món)', 
                        NEW.product_id, current_stock;
    END IF;

    -- 3. Nếu đủ hàng, cho phép INSERT tiếp tục
    RETURN NEW;
END;
$$ LANGUAGE plpgsql;


CREATE TRIGGER trg_check_stock
BEFORE INSERT ON sales
FOR EACH ROW
EXECUTE FUNCTION check_stock_before_sale();

