
CREATE TABLE products (
    product_id SERIAL PRIMARY KEY,
    name VARCHAR(50),
    price NUMERIC(10, 2)
);

INSERT INTO products (name, price) VALUES ('iPhone 15', 1000), ('MacBook Air', 1200);

CREATE TABLE orders (
    order_id SERIAL PRIMARY KEY,
    product_id INT REFERENCES products(product_id),
    quantity INT,
    total_amount NUMERIC
);

CREATE OR REPLACE FUNCTION calculate_total_amount()
RETURNS TRIGGER AS $$
DECLARE
    v_price NUMERIC;
BEGIN
    -- 1. Lấy giá sản phẩm từ bảng products
    SELECT price INTO v_price FROM products WHERE product_id = NEW.product_id;

    -- 2. Tính toán total_amount và gán vào bản ghi mới (NEW)
    NEW.total_amount := NEW.quantity * v_price;

    -- 3. Trả về NEW để tiếp tục quá trình INSERT
    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER trg_calculate_order_total
BEFORE INSERT ON orders
FOR EACH ROW
EXECUTE FUNCTION calculate_total_amount();

