--3
CREATE OR REPLACE FUNCTION log_customer_insert()
RETURNS TRIGGER AS $$
BEGIN
    INSERT INTO customer_log (customer_id, details)
    VALUES (NEW.customer_id, 'Đã thêm khách hàng mới: ' || NEW.name);
    RETURN NEW;
END;
$$ LANGUAGE plpgsql;
CREATE TRIGGER trg_after_insert_customer
AFTER INSERT ON customers
FOR EACH ROW
EXECUTE FUNCTION log_customer_insert();

