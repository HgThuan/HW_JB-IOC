ALTER TABLE employees ADD COLUMN status TEXT;

--5
create procedure update_employee_status(
    in p_emp_id int,
    out p_status TEXT
)
language plpgsql
as
$$
declare v_salary numeric(10,2);
    begin
        select e.salary into v_salary from employees e
        where e.id=p_emp_id;
        if not FOUND then
        raise exception 'Employee not found';
        end if;
        if v_salary <5000 then
            p_status := 'Junior';
        end if;
        if  v_salary between 5000 and 1000 then
            p_status := 'Middle';
        end if;
        if v_salary >10000 then
            p_status := 'senior';
        end if;
        update employees e
    set status=p_status
    where id=p_emp_id;
    end;
$$;

DO $$
    DECLARE
        v_out_status TEXT;
    BEGIN
        -- Gọi procedure cho nhân viên có ID là 1
        CALL update_employee_status(1, v_out_status);
        RAISE NOTICE 'Trạng thái mới: %', v_out_status;
    END $$;

