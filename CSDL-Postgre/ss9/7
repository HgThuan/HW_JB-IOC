CREATE OR REPLACE PROCEDURE add_order(
    p_customer_id INT, 
    p_amount NUMERIC
)
LANGUAGE plpgsql
AS $$
DECLARE
    v_customer_exists BOOLEAN;
BEGIN
    -- 1. Kiểm tra xem customer_id có tồn tại trong bảng Customers không
    SELECT EXISTS(SELECT 1 FROM Customers WHERE customer_id = p_customer_id) 
    INTO v_customer_exists;

    -- 2. Nếu không tồn tại, ném lỗi và dừng thực hiện
    IF NOT v_customer_exists THEN
        RAISE EXCEPTION 'Lỗi: Customer ID % không tồn tại trong hệ thống!', p_customer_id;
    END IF;

    -- 3. Nếu tồn tại, thực hiện thêm đơn hàng vào bảng Orders
    INSERT INTO Orders (customer_id, amount) 
    VALUES (p_customer_id, p_amount);

    -- Thông báo thành công (tùy chọn)
    RAISE NOTICE 'Đã thêm đơn hàng thành công cho khách hàng ID %', p_customer_id;
END;
$$;

CALL add_order(1, 500000);
