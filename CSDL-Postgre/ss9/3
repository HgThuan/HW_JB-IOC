CREATE TABLE Products (
    product_id INT PRIMARY KEY, -- Mặc định là Clustered Index trong SQL Server
    category_id INT,
    price NUMERIC(10, 2),
    stock_quantity INT
);

INSERT INTO Products (product_id, category_id, price, stock_quantity) VALUES
