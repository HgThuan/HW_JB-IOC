-- Xóa ràng buộc PK cũ nếu cần để chỉ định lại Clustered Index
CREATE CLUSTERED INDEX idx_products_category_id ON Products(category_id);

CREATE NONCLUSTERED INDEX idx_products_price ON Products(price);

SELECT * FROM Products 
WHERE category_id = 10 
ORDER BY price;
